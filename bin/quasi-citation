#!/usr/bin/env bash
# quasi-citation — verify draft citations against vault, produce HTML + bib.
#
# Usage:
#   quasi-citation run drafts/03-writing/差异.md
#   quasi-citation parse drafts/03-writing/差异.md -o /tmp/parse.json
#   quasi-citation resolve /tmp/parse.json -o /tmp/manifest.json
#   quasi-citation render /tmp/manifest.json --html-out /tmp/out.html --bib-out /tmp/out.bib

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.cache/quasi}"
PYTHON="$DATA_DIR/.venv/bin/python"

[ -x "$PYTHON" ] || "$PLUGIN_ROOT/scripts/bootstrap-venv.sh"

exec "$PYTHON" "$PLUGIN_ROOT/scripts/citation/citation.py" "$@"
