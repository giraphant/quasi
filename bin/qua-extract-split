#!/usr/bin/env bash
# qua-extract-split — Split a PDF into per-chapter files.
#
# Usage:
#   qua-extract-split INPUT.pdf --output-dir DIR [--max-chapters N]
#   qua-extract-split INPUT.pdf --output-dir DIR --chapters '<JSON>'
#   qua-extract-split INPUT.pdf --output-dir DIR --pages 15-32 --title "..."

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.cache/quasi}"
PYTHON="$DATA_DIR/.venv/bin/python"

[ -x "$PYTHON" ] || "$PLUGIN_ROOT/scripts/bootstrap-venv.sh"

exec "$PYTHON" "$PLUGIN_ROOT/scripts/extract/split_chapters.py" "$@"
