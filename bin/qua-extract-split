#!/usr/bin/env bash
# qua-extract-split — Split a PDF into per-chapter files.
#
# Usage:
#   qua-extract-split INPUT.pdf --output-dir DIR [--max-chapters N]
#   qua-extract-split INPUT.pdf --output-dir DIR --chapters '<JSON>'
#   qua-extract-split INPUT.pdf --output-dir DIR --pages 15-32 --title "..."

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$PLUGIN_ROOT/.venv-data}"
VENV="$DATA_DIR/.venv"

if [ ! -x "$VENV/bin/python" ]; then
    echo "[qua-extract-split] creating venv at $VENV ..." >&2
    mkdir -p "$DATA_DIR"
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install --quiet --upgrade pip
fi

if ! "$VENV/bin/python" -c "import fitz" 2>/dev/null; then
    echo "[qua-extract-split] installing pymupdf ..." >&2
    "$VENV/bin/pip" install --quiet pymupdf
fi

exec "$VENV/bin/python" "$PLUGIN_ROOT/scripts/extract/split_chapters.py" "$@"
