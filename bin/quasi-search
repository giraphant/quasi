#!/usr/bin/env bash
# quasi-search — Search books / papers via OpenLibrary, Crossref, Anna's Archive, etc.
#
# Usage:
#   quasi-search book  [--isbn|--title|--author|--subject|--query] [filter flags]
#   quasi-search paper [--doi|--title|--author|--query] [filter flags]

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.cache/quasi}"
PYTHON="$DATA_DIR/.venv/bin/python"

[ -x "$PYTHON" ] || "$PLUGIN_ROOT/scripts/bootstrap-venv.sh"

exec "$PYTHON" "$PLUGIN_ROOT/scripts/search/search.py" "$@"
