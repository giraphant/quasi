#!/usr/bin/env bash
# quasi-extract-epub — Extract chapter-level plain text from an EPUB.
#
# Usage:
#   quasi-extract-epub SOURCE_EPUB CHAPTERS_DIR

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"

exec python3 "$PLUGIN_ROOT/scripts/extract/process_epub.py" "$@"
