#!/usr/bin/env bash
# quasi-journal-report — Render a scored journal scan report (scan.md).
#
# Usage:
#   quasi-journal-report --papers PAPERS_JSON --scores SCORES_DIR --output PATH

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"

exec python3 "$PLUGIN_ROOT/scripts/journal/generate_scan_report.py" "$@"
