#!/usr/bin/env bash
# quasi-journal-fetch — Fetch a journal's paper list to JSON.
#
# Usage:
#   quasi-journal-fetch --journal-name "Full Name" --days-back N --output PATH

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.cache/quasi}"
PYTHON="$DATA_DIR/.venv/bin/python"

[ -x "$PYTHON" ] || "$PLUGIN_ROOT/scripts/bootstrap-venv.sh"

exec "$PYTHON" "$PLUGIN_ROOT/scripts/journal/fetch_papers.py" "$@"
