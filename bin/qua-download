#!/usr/bin/env bash
# qua-download — Download a paper/book by DOI / MD5 / manifest.
#
# Usage:
#   qua-download --doi "10.x/y" --output-dir DIR --filename SLUG ...
#   qua-download --md5 HASH --filename SLUG -o sources/
#   qua-download --manifest MANIFEST --batch --retry-wayback
#   qua-download --finalize-book --manifest MANIFEST --book-index N ...

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$PLUGIN_ROOT/.venv-data}"
VENV="$DATA_DIR/.venv"

if [ ! -x "$VENV/bin/python" ]; then
    echo "[qua-download] creating venv at $VENV ..." >&2
    mkdir -p "$DATA_DIR"
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install --quiet --upgrade pip
fi

if ! "$VENV/bin/python" -c "import requests" 2>/dev/null; then
    echo "[qua-download] installing requests ..." >&2
    "$VENV/bin/pip" install --quiet requests
fi

exec "$VENV/bin/python" "$PLUGIN_ROOT/scripts/download/download.py" "$@"
