#!/usr/bin/env bash
# qua-typecheck — Validate vault md files against quasi SPEC.
#
# Usage:
#   qua-typecheck                    # check $PWD/vault
#   qua-typecheck --path FILE_OR_DIR
#   qua-typecheck --quiet

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.cache/quasi}"
PYTHON="$DATA_DIR/.venv/bin/python"

[ -x "$PYTHON" ] || "$PLUGIN_ROOT/scripts/bootstrap-venv.sh"

exec "$PYTHON" "$PLUGIN_ROOT/scripts/typecheck/typecheck.py" "$@"
