#!/usr/bin/env bash
# quasi-helpers — skill-orchestration helpers (NOT an agent-callable bin).
#
# Aggregates the deterministic setup/teardown operations that live around
# map-reduce LLM agent dispatches (proofread-agent × 节, citation-agent × 批).
# Called from skill main process; never called from inside an agent.
#
# Nested subcommand:
#   quasi-helpers proofread {prepare|cleanup} [args...]
#       prepare draft.md → sections.json + 末尾 <!-- proofread:* --> 记录块
#       cleanup 审完后清记录块
#
#   quasi-helpers citation {parse|biblio|resolve|emit-bib} [args...]
#       parse     draft.md → parse.json
#       biblio    vault frontmatter → biblio.json
#       resolve   parse.json + biblio.json → manifest.json
#       emit-bib  manifest.json + biblio.json → references.bib (draft-level)
#
#   quasi-helpers localise {scan|write} [args...]
#       scan    book overviews → ISBN-keyed cndouban pending state
#       write   search result localisations.zh → .quasi/localise/cndouban.json
#
# Each nested subcommand has its own --help.

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.cache/quasi}"
PYTHON="$DATA_DIR/.venv/bin/python"

[ -x "$PYTHON" ] || "$PLUGIN_ROOT/scripts/bootstrap-venv.sh"

if [ $# -eq 0 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    cat <<'HELP'
quasi-helpers — skill-orchestration helpers (NOT an agent-callable bin).

Aggregates deterministic setup/teardown operations around map-reduce
LLM agent dispatches. Called from skill main process; never from agents.

Usage:
  quasi-helpers proofread {prepare|cleanup} [args...]
  quasi-helpers citation  {parse|biblio|resolve|emit-bib} [args...]
  quasi-helpers localise  {scan|write} [args...]

Each nested subcommand has its own --help, e.g.:
  quasi-helpers proofread prepare --help
  quasi-helpers citation parse --help
  quasi-helpers localise scan --help
HELP
    exit 0
fi

DOMAIN="$1"
shift

case "$DOMAIN" in
    proofread)
        exec "$PYTHON" "$PLUGIN_ROOT/scripts/proofread/proofread.py" "$@"
        ;;
    citation)
        exec "$PYTHON" "$PLUGIN_ROOT/scripts/citation/citation.py" "$@"
        ;;
    localise)
        exec "$PYTHON" "$PLUGIN_ROOT/scripts/localise/localise.py" "$@"
        ;;
    *)
        echo "quasi-helpers: unknown domain: $DOMAIN" >&2
        echo "valid: proofread | citation | localise" >&2
        exit 2
        ;;
esac
