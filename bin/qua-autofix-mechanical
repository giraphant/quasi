#!/usr/bin/env bash
# qua-autofix-mechanical — Layer 1+3 mechanical fixes for vault drift.
# Default dry-run; use --write to apply.
#
# Usage:
#   qua-autofix-mechanical --path FILE_OR_DIR
#   qua-autofix-mechanical --path FILE_OR_DIR --write

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$PLUGIN_ROOT/.venv-data}"
VENV="$DATA_DIR/.venv"

if [ ! -x "$VENV/bin/python" ]; then
    echo "[qua-autofix-mechanical] creating venv at $VENV ..." >&2
    mkdir -p "$DATA_DIR"
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install --quiet --upgrade pip
fi

if ! "$VENV/bin/python" -c "import pydantic, yaml" 2>/dev/null; then
    echo "[qua-autofix-mechanical] installing pydantic pyyaml ..." >&2
    "$VENV/bin/pip" install --quiet pydantic pyyaml
fi

exec "$VENV/bin/python" "$PLUGIN_ROOT/scripts/typecheck/autofix_mechanical.py" "$@"
