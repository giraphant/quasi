#!/usr/bin/env bash
# qua-autofix-mechanical — Layer 1+3 mechanical fixes for vault drift.
# Default dry-run; use --write to apply.
#
# Usage:
#   qua-autofix-mechanical --path FILE_OR_DIR
#   qua-autofix-mechanical --path FILE_OR_DIR --write

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.cache/quasi}"
PYTHON="$DATA_DIR/.venv/bin/python"

[ -x "$PYTHON" ] || "$PLUGIN_ROOT/scripts/bootstrap-venv.sh"

exec "$PYTHON" "$PLUGIN_ROOT/scripts/typecheck/autofix_mechanical.py" "$@"
