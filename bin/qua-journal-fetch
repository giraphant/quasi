#!/usr/bin/env bash
# qua-journal-fetch — Fetch a journal's paper list to JSON.
#
# Usage:
#   qua-journal-fetch --journal-name "Full Name" --days-back N --output PATH

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$PLUGIN_ROOT/.venv-data}"
VENV="$DATA_DIR/.venv"

if [ ! -x "$VENV/bin/python" ]; then
    echo "[qua-journal-fetch] creating venv at $VENV ..." >&2
    mkdir -p "$DATA_DIR"
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install --quiet --upgrade pip
fi

if ! "$VENV/bin/python" -c "import requests" 2>/dev/null; then
    echo "[qua-journal-fetch] installing requests ..." >&2
    "$VENV/bin/pip" install --quiet requests
fi

exec "$VENV/bin/python" "$PLUGIN_ROOT/scripts/journal/fetch_papers.py" "$@"
