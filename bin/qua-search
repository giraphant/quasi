#!/usr/bin/env bash
# qua-search — Search books / papers via OpenLibrary, Crossref, Anna's Archive, etc.
#
# Usage:
#   qua-search books --author "..." --limit N
#   qua-search papers --author "..." --limit N
#   qua-search books --source aa "TITLE" --author "AUTHOR" --limit N
#   qua-search validate --manifest PATH
#   qua-search metadata --manifest PATH --all

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$PLUGIN_ROOT/.venv-data}"
VENV="$DATA_DIR/.venv"

if [ ! -x "$VENV/bin/python" ]; then
    echo "[qua-search] creating venv at $VENV ..." >&2
    mkdir -p "$DATA_DIR"
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install --quiet --upgrade pip
fi

if ! "$VENV/bin/python" -c "import requests, bs4" 2>/dev/null; then
    echo "[qua-search] installing requests beautifulsoup4 ..." >&2
    "$VENV/bin/pip" install --quiet requests beautifulsoup4
fi

exec "$VENV/bin/python" "$PLUGIN_ROOT/scripts/search/search.py" "$@"
