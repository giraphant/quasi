#!/usr/bin/env bash
# quasi-proofread — section split / changelog merge / HTML render.
# The proofread-agent does the editing in the main loop; this CLI is the
# deterministic plumbing around it.
#
# Usage:
#   quasi-proofread split drafts/03-writing/差异.md -o /tmp/sections.json
#   quasi-proofread merge /path/to/sections-changelogs/ -o /tmp/changelog.json
#   quasi-proofread render /tmp/changelog.json -o /tmp/changelog.html

set -e

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
PLUGIN_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.cache/quasi}"
PYTHON="$DATA_DIR/.venv/bin/python"

[ -x "$PYTHON" ] || "$PLUGIN_ROOT/scripts/bootstrap-venv.sh"

exec "$PYTHON" "$PLUGIN_ROOT/scripts/proofread/proofread.py" "$@"
